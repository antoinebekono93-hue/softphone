generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Auth.js required models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Application models
// ============================================

// Removed Enums for SQLite compatibility. Use Strings in code.
// UserRole: OWNER, ADMIN, MANAGER, AGENT
// PlanStatus: ACTIVE, TRIALING, PAST_DUE, CANCELED, UNPAID
// PhoneNumberStatus: ACTIVE, SUSPENDED, RELEASED
// SimType: PHYSICAL, ESIM
// SimStatus: ACTIVE, SUSPENDED
// MessageStatus: DELIVERED, UNDELIVERED, IN_FLIGHT
// MessageType: SMS, MMS
// CallDirection: INBOUND, OUTBOUND
// CallStatus: INITIATED, RINGING, IN_PROGRESS, COMPLETED, BUSY, NO_ANSWER, CANCELED, FAILED, VOICEMAIL

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  isSuperAdmin   Boolean  @default(false)
  role           String   @default("AGENT")
  organizationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  accounts       Account[]
  sessions       Session[]
  phoneNumbers   PhoneNumber[]  @relation("AssignedUser")
  callLogs       CallLog[]
  smsMessages    SmsMessage[]
  opportunities  Opportunity[]
  internalNotes  InternalNote[]

  @@index([organizationId])
  @@index([email])
}

model Organization {
  id   String @id @default(cuid())
  name String
  slug String @unique

  // Telnyx Integration
  telnyxApiKey          String? // Encrypted API Key for BYOK (Bring Your Own Key) mode
  telnyxConnectionId    String? // SIP Connection ID for WebRTC

  // Stripe
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // Flutterwave
  flutterwaveCustomerId String? @unique

  // Plan
  pricingPlanId String?
  planStatus    String @default("UNPAID")

  // Usage tracking
  minutesUsedThisMonth Int      @default(0)
  usageResetDate       DateTime @default(now())

  // Wallet & Prepaid
  walletBalance Float @default(0.0) // Balance in USD for prepaid services

  // God Mode Configuration (Quotas & Limits)
  tenantSettings Json?

  // KYC & Compliance
  kycStatus      String  @default("UNVERIFIED") // UNVERIFIED, PENDING, APPROVED, REJECTED
  kycDocumentUrl String?
  businessName   String?
  businessRegistrationNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users               User[]
  phoneNumbers        PhoneNumber[]
  messagingProfiles   MessagingProfile[]
  simCards            SimCard[]
  callLogs            CallLog[]
  contacts            Contact[]
  automationRules     AutomationRule[]
  smsMessages         SmsMessage[]
  pricingPlan         PricingPlan? @relation(fields: [pricingPlanId], references: [id])
  aiAgents            VoiceAIAgent[]
  walletTransactions  WalletTransaction[]
  whatsappAccount     WhatsAppAccount?
  campaigns           Campaign[]
  whatsappTemplates   WhatsAppTemplate[]
  opportunities       Opportunity[]
  internalNotes       InternalNote[]
  contactGroups       ContactGroup[]
  sequences           Sequence[]
  numberOrders        NumberOrder[]
  verifyProfiles      VerifyProfile[]
  verificationLogs    VerificationLog[]
  rcsSettings         RcsSettings?

  @@index([slug])
  @@index([pricingPlanId])
  @@index([stripeCustomerId])
}

model MessagingProfile {
  id             String        @id @default(cuid())
  telnyxId       String        @unique // The ID returned by Telnyx
  name           String
  webhookUrl     String?
  
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumbers   PhoneNumber[]

  @@index([organizationId])
}

model PhoneNumber {
  id                 String            @id @default(cuid())
  number             String            @unique // E.164 format
  friendlyName       String?
  telnyxId           String            @unique // Telnyx Phone Number ID
  country            String?           // ISO 3166-1 alpha-2
  status             String            @default("ACTIVE")
  
  organizationId     String
  assignedUserId     String? // Can be assigned to a specific user or left null for the entire org
  messagingProfileId String? // The linked messaging profile

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser     User?             @relation("AssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messagingProfile MessagingProfile? @relation(fields: [messagingProfileId], references: [id], onDelete: SetNull)
  voiceAIAgent     VoiceAIAgent?
  callLogs         CallLog[]
  smsMessages      SmsMessage[]
  campaigns        Campaign[]

  @@index([organizationId])
  @@index([number])
  @@index([messagingProfileId])
}

model Contact {
  id             String   @id @default(cuid())
  name           String?
  company        String?
  email          String?
  phone          String   // E.164
  notes          String?
  
  // AI Intelligence
  leadScore      Int?     // 0 to 100
  sentiment      String?  // POSITIVE, NEUTRAL, NEGATIVE
  
  organizationId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  groups       ContactGroup[]
  callLogs     CallLog[]
  smsMessages  SmsMessage[]
  campaignRecipients CampaignRecipient[]
  opportunities      Opportunity[]
  internalNotes      InternalNote[]
  sequenceEnrollments SequenceEnrollment[]

  @@unique([organizationId, phone])
  @@index([organizationId])
}

model ContactGroup {
  id             String    @id @default(cuid())
  name           String
  description    String?
  
  organizationId String

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]

  @@index([organizationId])
}

model CallLog {
  id                   String        @id @default(cuid())
  telnyxCallControlId  String        @unique // The unique Call Control ID from Telnyx
  direction            String
  status               String        @default("INITIATED")

  fromNumber String
  toNumber   String
  duration   Int           @default(0) // in seconds
  
  // Quality and Diagnostics
  hangupCause          String?
  sipHangupCause       String?
  mosScore             Float?

  // AI Intelligence
  recordingUrl         String?
  transcriptionText    String?
  aiSummary            String?
  amdResult            String? // Answering Machine Detection result

  organizationId String
  userId         String?
  phoneNumberId  String?
  contactId      String?

  startedAt  DateTime  @default(now())
  answeredAt DateTime?
  endedAt    DateTime?

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  phoneNumber  PhoneNumber? @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([contactId])
  @@index([startedAt])
  @@index([telnyxCallControlId])
}

model SmsMessage {
  id               String        @id @default(cuid())
  telnyxMessageId  String        @unique
  direction        String
  body             String
  status           String        @default("IN_FLIGHT")
  type             String        @default("SMS")
  cost             Float         @default(0.0)
  country          String?
  mediaUrls        String[]      @default([])
  agentMessage     String?       // For RCS Rich Cards/Carousels
  
  fromNumber String
  toNumber   String

  organizationId String
  userId         String?
  phoneNumberId  String?
  contactId      String?

  sentAt     DateTime  @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  phoneNumber  PhoneNumber? @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([contactId])
}

model AutomationRule {
  id             String  @id @default(cuid())
  name           String
  triggerType    String  // "MISSED_CALL", "NEW_VOICEMAIL", "AFTER_HOURS_SMS"
  actionType     String  // "SEND_SMS", "SEND_TO_SLACK"
  actionPayload  String // JSON string containing the action details (e.g. { message: "Hi! We missed..." })
  isActive       Boolean @default(true)

  organizationId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model PricingPlan {
  id              String   @id @default(cuid())
  name            String
  stripePriceId   String?  @unique
  flutterwavePlanId String? @unique
  monthlyPrice    Float    @default(0)
  
  // Quotas
  includedMinutes Int      @default(0)
  includedSms     Int      @default(0)
  
  isActive        Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations Organization[]
  features      PlanFeature[]
}

model PlanFeature {
  id            String   @id @default(cuid())
  name          String   // e.g. "AI Transcriptions", "Visual IVR"
  pricingPlanId String

  pricingPlan   PricingPlan @relation(fields: [pricingPlanId], references: [id], onDelete: Cascade)

  @@index([pricingPlanId])
}

model VoiceAIAgent {
  id             String   @id @default(cuid())
  name           String
  prompt         String
  greeting       String?
  voice          String   @default("alloy")
  language       String   @default("fr-FR")
  isActive       Boolean  @default(true)
  telnyxId       String?  @unique
  
  organizationId String
  phoneNumberId  String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumber  PhoneNumber? @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

model SimCard {
  id             String    @id @default(cuid())
  iccid          String    @unique
  telnyxSimId    String    @unique
  type           String    @default("ESIM")
  status         String    @default("ACTIVE")
  name           String?
  dataUsedMB     Float     @default(0.0)
  dataLimitMB    Float?
  alertEnabled   Boolean   @default(false)
  publicIpEnabled Boolean  @default(false)
  voiceEnabled   Boolean   @default(false)
  voicePhoneNumber String?
  voiceForwarding  String?
  voiceScreening   String?
  lpaCode        String?
  
  organizationId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model WalletTransaction {
  id             String          @id @default(cuid())
  amount         Float           // Positive = credit, Negative = debit
  type           String
  description    String
  organizationId String
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
}

model WhatsAppAccount {
  id             String   @id @default(cuid())
  wabaId         String
  phoneNumberId  String
  phoneNumber    String
  accessToken    String
  status         String   @default("ACTIVE")

  organizationId String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Campaign {
  id             String   @id @default(cuid())
  name           String
  status         String   @default("DRAFT") // DRAFT, SCHEDULED, SENDING, COMPLETED, CANCELLED
  scheduledAt    DateTime?
  
  // Analytics
  sentCount      Int      @default(0)
  deliveredCount Int      @default(0)
  readCount      Int      @default(0)
  repliedCount   Int      @default(0)

  // Content
  templateId     String?
  body           String?  // text content if not using a template
  phoneNumberId  String?  // The sender number

  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumber    PhoneNumber?        @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)
  template       WhatsAppTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients     CampaignRecipient[]

  @@index([organizationId])
}

model CampaignRecipient {
  id         String   @id @default(cuid())
  campaignId String
  contactId  String
  status     String   @default("PENDING") // PENDING, SENT, DELIVERED, READ, FAILED
  messageId  String?  // Telnyx message ID when sent

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
}

model WhatsAppTemplate {
  id             String   @id @default(cuid())
  name           String
  language       String   @default("fr")
  category       String   @default("MARKETING") // MARKETING, UTILITY, AUTHENTICATION
  status         String   @default("APPROVED")  // PENDING, APPROVED, REJECTED
  content        String
  
  organizationId String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns      Campaign[]

  @@index([organizationId])
}

model Opportunity {
  id             String   @id @default(cuid())
  name           String
  stage          String   @default("NEW") // NEW, QUALIFIED, PROPOSITION, WON, LOST
  expectedRevenue Float   @default(0.0)
  probability    Int      @default(10) // 0 to 100
  priority       Int      @default(0) // 0 to 3 stars
  
  contactId      String?
  organizationId String
  assignedUserId String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser   User?        @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  internalNotes  InternalNote[]

  @@index([organizationId])
  @@index([contactId])
}

model InternalNote {
  id             String   @id @default(cuid())
  content        String
  
  opportunityId  String?
  contactId      String?
  organizationId String
  authorId       String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([opportunityId])
  @@index([contactId])
}

// ============================================
// Global System Settings (Singleton)
// ============================================
model SystemSettings {
  id                   String   @id @default("default")
  smsRate              Float    @default(0.05)
  callRatePerMinute    Float    @default(0.02)
  aiAgentRatePerMinute Float    @default(0.15)
  whatsappRate         Float    @default(0.02)
  phoneNumberRate      Float    @default(1.00)
  eSimRate             Float    @default(5.00)

  telnyxApiKey         String?  // Global Telnyx API Key
  telnyxConnectionId   String?  // Global SIP Connection ID

  updatedAt            DateTime @updatedAt
}

model Sequence {
  id             String         @id @default(cuid())
  name           String
  description    String?
  isActive       Boolean        @default(false)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  steps          SequenceStep[]
  enrollments    SequenceEnrollment[]
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model SequenceStep {
  id             String         @id @default(cuid())
  sequenceId     String
  stepOrder      Int            // 1, 2, 3...
  delayHours     Int            // Hours to wait after the previous step (or after enrollment if step 1)
  actionType     String         // "SMS", "WHATSAPP", "AI_CALL"
  content        String?        // SMS body or AI Prompt
  templateId     String?        // for WhatsApp
  
  sequence       Sequence       @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
}

model SequenceEnrollment {
  id             String         @id @default(cuid())
  sequenceId     String
  contactId      String
  currentStep    Int            @default(1)
  status         String         @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED, FAILED
  nextRunAt      DateTime?      // When the next step should be executed
  
  sequence       Sequence       @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contact        Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, contactId])
  @@index([sequenceId])
  @@index([contactId])
}

model NumberOrder {
  id               String   @id @default(cuid())
  telnyxOrderId    String   @unique
  type             String   // "STANDARD", "BULK", "ADVANCED"
  status           String   @default("pending") // pending, processing, success, partial_success, failed, exception
  phoneNumbers     String?  // JSON string of requested numbers or criteria
  
  organizationId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

model VerifyProfile {
  id               String   @id // Using Telnyx ID
  name             String
  language         String   @default("en-US")
  settings         String?  // JSON string containing sms, call, dtmf_confirm configurations
  
  organizationId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs         VerificationLog[]

  @@index([organizationId])
}

model VerificationLog {
  id               String   @id // Using Telnyx ID
  phoneNumber      String
  status           String   @default("pending") // pending, accepted, rejected, expired, max_attempts_exceeded, invalid, error
  type             String   // sms, call, flashcall, dtmf_confirm
  
  verifyProfileId  String
  organizationId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  verifyProfile    VerifyProfile @relation(fields: [verifyProfileId], references: [id], onDelete: Cascade)
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([verifyProfileId])
  @@index([phoneNumber])
}

model RcsSettings {
  id                 String   @id @default(cuid())
  organizationId     String   @unique
  agentId            String?  // Telnyx RCS Agent ID
  messagingProfileId String?  // Telnyx Messaging Profile ID assigned to RCS
  aiAssistantId      String?  // Telnyx AI Assistant ID to automate replies
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
