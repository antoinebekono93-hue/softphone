generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String         @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  isSuperAdmin   Boolean        @default(false)
  role           String         @default("AGENT")
  organizationId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       Account[]
  callLogs       CallLog[]
  internalNotes  InternalNote[]
  opportunities  Opportunity[]
  phoneNumbers   PhoneNumber[]  @relation("AssignedUser")
  sessions       Session[]
  smsMessages    SmsMessage[]
  contacts       Contact[]      @relation("AssignedContactUser")
  organization   Organization?  @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([email])
}

model Organization {
  id                         String              @id @default(cuid())
  name                       String
  slug                       String              @unique
  telnyxApiKey               String?
  telnyxConnectionId         String?
  stripeCustomerId           String?             @unique
  stripeSubscriptionId       String?             @unique
  flutterwaveCustomerId      String?             @unique
  pricingPlanId              String?
  planStatus                 String              @default("UNPAID")
  minutesUsedThisMonth       Int                 @default(0)
  usageResetDate             DateTime            @default(now())
  walletBalance              Float               @default(0.0)
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  businessName               String?
  businessRegistrationNumber String?
  kycDocumentUrl             String?
  kycStatus                  String              @default("UNVERIFIED")
  tenantSettings             Json?
  automationRules            AutomationRule[]
  callLogs                   CallLog[]
  campaigns                  Campaign[]
  contacts                   Contact[]
  contactGroups              ContactGroup[]
  internalNotes              InternalNote[]
  messagingProfiles          MessagingProfile[]
  numberOrders               NumberOrder[]
  opportunities              Opportunity[]
  pricingPlan                PricingPlan?        @relation(fields: [pricingPlanId], references: [id])
  phoneNumbers               PhoneNumber[]
  rcsSettings                RcsSettings?
  sequences                  Sequence[]
  simCards                   SimCard[]
  smsMessages                SmsMessage[]
  users                      User[]
  verificationLogs           VerificationLog[]
  verifyProfiles             VerifyProfile[]
  aiAgents                   VoiceAIAgent[]
  walletTransactions         WalletTransaction[]
  whatsappAccount            WhatsAppAccount?
  whatsappTemplates          WhatsAppTemplate[]
  whatsappFlows              WhatsAppFlow[]
  whatsappFlowEnrollments    WhatsAppFlowEnrollment[]

  @@index([slug])
  @@index([pricingPlanId])
  @@index([stripeCustomerId])
}

model MessagingProfile {
  id             String        @id @default(cuid())
  telnyxId       String        @unique
  name           String
  webhookUrl     String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumbers   PhoneNumber[]

  @@index([organizationId])
}

model PhoneNumber {
  id                 String            @id @default(cuid())
  number             String            @unique
  friendlyName       String?
  telnyxId           String            @unique
  country            String?
  status             String            @default("ACTIVE")
  organizationId     String
  assignedUserId     String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  messagingProfileId String?
  callLogs           CallLog[]
  campaigns          Campaign[]
  assignedUser       User?             @relation("AssignedUser", fields: [assignedUserId], references: [id])
  messagingProfile   MessagingProfile? @relation(fields: [messagingProfileId], references: [id])
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  smsMessages        SmsMessage[]
  voiceAIAgent       VoiceAIAgent?

  @@index([organizationId])
  @@index([number])
  @@index([messagingProfileId])
}

model Contact {
  id                  String               @id @default(cuid())
  name                String?
  company             String?
  email               String?
  phone               String
  notes               String?
  organizationId      String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  leadScore           Int?
  sentiment           String?
  optedOut            Boolean              @default(false)
  optInSource         String?
  optInTimestamp      DateTime?
  callLogs            CallLog[]
  campaignRecipients  CampaignRecipient[]
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  internalNotes       InternalNote[]
  opportunities       Opportunity[]
  sequenceEnrollments SequenceEnrollment[]
  whatsappFlowEnrollments WhatsAppFlowEnrollment[]
  smsMessages         SmsMessage[]
  groups              ContactGroup[]       @relation("ContactToContactGroup")
  assignedUserId      String?
  assignedUser        User?                @relation("AssignedContactUser", fields: [assignedUserId], references: [id])

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([assignedUserId])
}

model ContactGroup {
  id             String       @id @default(cuid())
  name           String
  description    String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]    @relation("ContactToContactGroup")

  @@index([organizationId])
}

model CallLog {
  id                  String       @id @default(cuid())
  telnyxCallControlId String       @unique
  direction           String
  status              String       @default("INITIATED")
  fromNumber          String
  toNumber            String
  duration            Int          @default(0)
  recordingUrl        String?
  transcriptionText   String?
  aiSummary           String?
  organizationId      String
  userId              String?
  phoneNumberId       String?
  contactId           String?
  startedAt           DateTime     @default(now())
  answeredAt          DateTime?
  endedAt             DateTime?
  amdResult           String?
  hangupCause         String?
  mosScore            Float?
  sipHangupCause      String?
  contact             Contact?     @relation(fields: [contactId], references: [id])
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumber         PhoneNumber? @relation(fields: [phoneNumberId], references: [id])
  user                User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([contactId])
  @@index([startedAt])
  @@index([telnyxCallControlId])
}

model SmsMessage {
  id              String       @id @default(cuid())
  telnyxMessageId String       @unique
  direction       String
  body            String
  status          String       @default("IN_FLIGHT")
  type            String       @default("SMS")
  cost            Float        @default(0.0)
  country         String?
  fromNumber      String
  toNumber        String
  organizationId  String
  userId          String?
  phoneNumberId   String?
  contactId       String?
  sentAt          DateTime     @default(now())
  agentMessage    String?
  mediaUrls       String[]     @default([])
  contact         Contact?     @relation(fields: [contactId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumber     PhoneNumber? @relation(fields: [phoneNumberId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([contactId])
}

model AutomationRule {
  id             String       @id @default(cuid())
  name           String
  triggerType    String
  actionType     String
  actionPayload  String
  isActive       Boolean      @default(true)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model PricingPlan {
  id                String         @id @default(cuid())
  name              String
  stripePriceId     String?        @unique
  flutterwavePlanId String?        @unique
  monthlyPrice      Float          @default(0)
  includedMinutes   Int            @default(0)
  includedSms       Int            @default(0)
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  organizations     Organization[]
  features          PlanFeature[]
}

model PlanFeature {
  id            String      @id @default(cuid())
  name          String
  pricingPlanId String
  pricingPlan   PricingPlan @relation(fields: [pricingPlanId], references: [id], onDelete: Cascade)

  @@index([pricingPlanId])
}

model VoiceAIAgent {
  id             String       @id @default(cuid())
  name           String
  prompt         String
  voice          String       @default("alloy")
  language       String       @default("fr-FR")
  isActive       Boolean      @default(true)
  organizationId String
  phoneNumberId  String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  greeting       String?
  telnyxId       String?      @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumber    PhoneNumber? @relation(fields: [phoneNumberId], references: [id])

  @@index([organizationId])
}

model SimCard {
  id               String       @id @default(cuid())
  iccid            String       @unique
  telnyxSimId      String       @unique
  type             String       @default("ESIM")
  status           String       @default("ACTIVE")
  name             String?
  dataUsedMB       Float        @default(0.0)
  dataLimitMB      Float?
  alertEnabled     Boolean      @default(false)
  lpaCode          String?
  organizationId   String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  publicIpEnabled  Boolean      @default(false)
  voiceEnabled     Boolean      @default(false)
  voiceForwarding  String?
  voicePhoneNumber String?
  voiceScreening   String?
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model WalletTransaction {
  id             String       @id @default(cuid())
  amount         Float
  type           String
  description    String
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
}

model WhatsAppAccount {
  id             String       @id @default(cuid())
  wabaId         String
  phoneNumberId  String
  phoneNumber    String
  accessToken    String
  status         String       @default("ACTIVE")
  organizationId String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Campaign {
  id             String              @id @default(cuid())
  name           String
  status         String              @default("DRAFT")
  scheduledAt    DateTime?
  sentCount      Int                 @default(0)
  deliveredCount Int                 @default(0)
  readCount      Int                 @default(0)
  repliedCount   Int                 @default(0)
  templateId     String?
  body           String?
  organizationId String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  phoneNumberId  String?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumber    PhoneNumber?        @relation(fields: [phoneNumberId], references: [id])
  template       WhatsAppTemplate?   @relation(fields: [templateId], references: [id])
  recipients     CampaignRecipient[]

  @@index([organizationId])
}

model CampaignRecipient {
  id         String   @id @default(cuid())
  campaignId String
  contactId  String
  status     String   @default("PENDING")
  messageId  String?
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
}

model WhatsAppTemplate {
  id             String       @id @default(cuid())
  name           String
  language       String       @default("fr")
  category       String       @default("MARKETING")
  status         String       @default("APPROVED")
  content        String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  campaigns      Campaign[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Opportunity {
  id              String         @id @default(cuid())
  name            String
  stage           String         @default("NEW")
  expectedRevenue Float          @default(0.0)
  probability     Int            @default(10)
  priority        Int            @default(0)
  contactId       String?
  organizationId  String
  assignedUserId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  internalNotes   InternalNote[]
  assignedUser    User?          @relation(fields: [assignedUserId], references: [id])
  contact         Contact?       @relation(fields: [contactId], references: [id])
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
}

model InternalNote {
  id             String       @id @default(cuid())
  content        String
  opportunityId  String?
  contactId      String?
  organizationId String
  authorId       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([opportunityId])
  @@index([contactId])
}

model SystemSettings {
  id                          String   @id @default("default")
  smsRate                     Float    @default(0.05)
  callRatePerMinute           Float    @default(0.02)
  aiAgentRatePerMinute        Float    @default(0.15)
  whatsappRate                Float    @default(0.02)
  phoneNumberRate             Float    @default(1.00)
  eSimRate                    Float    @default(5.00)
  telnyxApiKey                String?
  telnyxConnectionId          String?
  updatedAt                   DateTime @updatedAt
  phoneNumberMarkupFixed      Float    @default(0.0)
  phoneNumberMarkupMultiplier Float    @default(2.5)
}

model Sequence {
  id             String               @id @default(cuid())
  name           String
  description    String?
  isActive       Boolean              @default(false)
  organizationId String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollments    SequenceEnrollment[]
  steps          SequenceStep[]

  @@index([organizationId])
}

model SequenceStep {
  id         String   @id @default(cuid())
  sequenceId String
  stepOrder  Int
  delayHours Int
  actionType String
  content    String?
  templateId String?
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
}

model SequenceEnrollment {
  id          String    @id @default(cuid())
  sequenceId  String
  contactId   String
  currentStep Int       @default(1)
  status      String    @default("ACTIVE")
  nextRunAt   DateTime?
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sequence    Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, contactId])
  @@index([sequenceId])
  @@index([contactId])
}

model NumberOrder {
  id             String       @id @default(cuid())
  telnyxOrderId  String       @unique
  type           String
  status         String       @default("pending")
  phoneNumbers   String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

model VerifyProfile {
  id             String            @id
  name           String
  language       String            @default("en-US")
  settings       String?
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  logs           VerificationLog[]
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model VerificationLog {
  id              String        @id
  phoneNumber     String
  status          String        @default("pending")
  type            String
  verifyProfileId String
  organizationId  String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  verifyProfile   VerifyProfile @relation(fields: [verifyProfileId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([verifyProfileId])
  @@index([phoneNumber])
}

model RcsSettings {
  id                 String       @id @default(cuid())
  organizationId     String       @unique
  agentId            String?
  messagingProfileId String?
  aiAssistantId      String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model WhatsAppFlow {
  id             String       @id @default(cuid())
  name           String
  nodes          Json         @default("[]")
  edges          Json         @default("[]")
  isActive       Boolean      @default(false)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollments    WhatsAppFlowEnrollment[]

  @@index([organizationId])
}

model WhatsAppFlowEnrollment {
  id             String       @id @default(cuid())
  flowId         String
  contactId      String
  currentNodeId  String?      // The ID of the current node executing or waiting
  status         String       @default("ACTIVE") // ACTIVE, COMPLETED, FAILED, PAUSED
  nextRunAt      DateTime?    // If waiting on a Delay node
  variables      Json         @default("{}") // State variables for the flow run
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  flow           WhatsAppFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([flowId, contactId])
  @@index([flowId])
  @@index([contactId])
  @@index([organizationId])
  @@index([nextRunAt])
}
