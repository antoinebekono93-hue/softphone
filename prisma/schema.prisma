generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String         @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  isSuperAdmin   Boolean        @default(false)
  role           String         @default("AGENT")
  organizationId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       Account[]
  callLogs       CallLog[]
  internalNotes  InternalNote[]
  opportunities  Opportunity[]
  phoneNumbers   PhoneNumber[]  @relation("AssignedUser")
  sessions       Session[]
  smsMessages    SmsMessage[]
  contacts       Contact[]      @relation("AssignedContactUser")
  organization   Organization?  @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([email])
}

model Organization {
  id                         String                   @id @default(cuid())
  name                       String
  slug                       String                   @unique
  telnyxApiKey               String?
  telnyxConnectionId         String?
  stripeCustomerId           String?                  @unique
  stripeSubscriptionId       String?                  @unique
  flutterwaveCustomerId      String?                  @unique
  pricingPlanId              String?
  planStatus                 String                   @default("UNPAID")
  minutesUsedThisMonth       Int                      @default(0)
  usageResetDate             DateTime                 @default(now())
  walletBalance              Float                    @default(0.0)
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  businessName               String?
  businessRegistrationNumber String?
  kycDocumentUrl             String?
  kycStatus                  String                   @default("UNVERIFIED")
  calComApiKey               String?
  calComEventId              String?
  webhookUrl                 String?
  webhookSecret              String?
  tenantSettings             Json?
  automationWorkflows        AutomationWorkflow[]
  callLogs                   CallLog[]
  campaigns                  Campaign[]
  contacts                   Contact[]
  contactGroups              ContactGroup[]
  internalNotes              InternalNote[]
  messagingProfiles          MessagingProfile[]
  numberOrders               NumberOrder[]
  opportunities              Opportunity[]
  pricingPlan                PricingPlan?             @relation(fields: [pricingPlanId], references: [id])
  phoneNumbers               PhoneNumber[]
  rcsSettings                RcsSettings?
  sequences                  Sequence[]
  simCards                   SimCard[]
  smsMessages                SmsMessage[]
  users                      User[]
  verificationLogs           VerificationLog[]
  verifyProfiles             VerifyProfile[]
  aiEmployees                AIEmployee[]
  knowledgeBases             KnowledgeBase[]
  ecommerceStores            EcommerceStore[]
  carts                      Cart[]
  walletTransactions         WalletTransaction[]
  whatsappAccount            WhatsAppAccount?
  whatsappTemplates          WhatsAppTemplate[]
  whatsappFlows              WhatsAppFlow[]
  whatsappFlowEnrollments    WhatsAppFlowEnrollment[]
  quotes                     Quote[]
  invoices                   Invoice[]
  tickets                    Ticket[]
  products                   Product[]
  socialAccounts             SocialAccount[]
  socialPosts                SocialPost[]
  socialMessages             SocialMessage[]

  @@index([slug])
  @@index([pricingPlanId])
  @@index([stripeCustomerId])
}

model MessagingProfile {
  id             String        @id @default(cuid())
  telnyxId       String        @unique
  name           String
  webhookUrl     String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumbers   PhoneNumber[]

  @@index([organizationId])
}

model PhoneNumber {
  id                 String            @id @default(cuid())
  number             String            @unique
  friendlyName       String?
  telnyxId           String            @unique
  country            String?
  status             String            @default("ACTIVE")
  organizationId     String
  assignedUserId     String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  messagingProfileId String?
  callLogs           CallLog[]
  campaigns          Campaign[]
  assignedUser       User?             @relation("AssignedUser", fields: [assignedUserId], references: [id])
  messagingProfile   MessagingProfile? @relation(fields: [messagingProfileId], references: [id])
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  smsMessages        SmsMessage[]
  aiEmployee         AIEmployee?

  @@index([organizationId])
  @@index([number])
  @@index([messagingProfileId])
}

model Contact {
  id                      String                   @id @default(cuid())
  name                    String?
  company                 String?
  email                   String? // Phase 7: Email address
  instagramId             String? // Phase 7: Instagram user ID
  phone                   String
  notes                   String?
  organizationId          String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  leadScore               Int?
  sentiment               String?
  optedOut                Boolean                  @default(false)
  optInSource             String?
  optInTimestamp          DateTime?
  totalSpent              Float                    @default(0.0)
  purchaseCount           Int                      @default(0)
  lastPurchaseAt          DateTime?
  isVip                   Boolean                  @default(false)
  botMode                 Boolean                  @default(false) // Phase 5: Géré par l'IA Autonome RAG
  openaiThreadId          String? // Phase 5: ID du Thread conversationnel OpenAI
  escalationStatus        String                   @default("NONE") // NONE, REQUESTED, RESOLVED
  escalationReason        String?
  waitingForCsatTicketId  String?
  churnRiskScore          Int                      @default(0) // Phase 6: Score de risque de churn (0-100)
  lifetimeValue           Float                    @default(0.0) // Phase 6: Valeur à vie du client
  aiSummary               String? // Phase 4: Résumé IA des intéractions WhatsApp
  callLogs                CallLog[]
  campaignRecipients      CampaignRecipient[]
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  internalNotes           InternalNote[]
  opportunities           Opportunity[]
  sequenceEnrollments     SequenceEnrollment[]
  whatsappFlowEnrollments WhatsAppFlowEnrollment[]
  quotes                  Quote[]
  invoices                Invoice[]
  tickets                 Ticket[]
  smsMessages             SmsMessage[]
  socialMessages          SocialMessage[]
  groups                  ContactGroup[]           @relation("ContactToContactGroup")
  assignedUserId          String?
  assignedUser            User?                    @relation("AssignedContactUser", fields: [assignedUserId], references: [id])

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([assignedUserId])
}

model ContactGroup {
  id             String       @id @default(cuid())
  name           String
  description    String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]    @relation("ContactToContactGroup")

  @@index([organizationId])
}

model CallLog {
  id                  String       @id @default(cuid())
  telnyxCallControlId String       @unique
  direction           String
  status              String       @default("INITIATED")
  fromNumber          String
  toNumber            String
  duration            Int          @default(0)
  recordingUrl        String?
  transcriptionText   String?
  transcript          Json?
  qaScore             Int?
  qaFeedback          String?
  aiSummary           String?
  organizationId      String
  userId              String?
  phoneNumberId       String?
  contactId           String?
  startedAt           DateTime     @default(now())
  answeredAt          DateTime?
  endedAt             DateTime?
  amdResult           String?
  hangupCause         String?
  mosScore            Float?
  sipHangupCause      String?
  contact             Contact?     @relation(fields: [contactId], references: [id])
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumber         PhoneNumber? @relation(fields: [phoneNumberId], references: [id])
  user                User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([contactId])
  @@index([startedAt])
  @@index([telnyxCallControlId])
}

model SmsMessage {
  id              String       @id @default(cuid())
  telnyxMessageId String       @unique
  direction       String
  body            String
  status          String       @default("IN_FLIGHT")
  type            String       @default("SMS")
  cost            Float        @default(0.0)
  country         String?
  fromNumber      String
  toNumber        String
  organizationId  String
  userId          String?
  phoneNumberId   String?
  contactId       String?
  sentAt          DateTime     @default(now())
  agentMessage    String?
  mediaUrls       String[]     @default([])
  contact         Contact?     @relation(fields: [contactId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumber     PhoneNumber? @relation(fields: [phoneNumberId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([contactId])
}

model AutomationWorkflow {
  id             String    @id @default(cuid())
  name           String
  description    String?
  nodes          Json      @default("[]")
  edges          Json      @default("[]")
  isActive       Boolean   @default(false)
  triggerType    String    @default("MANUAL") // CALL_MISSED, TICKET_CREATED, SCHEDULED, MANUAL
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs           WorkflowRun[]

  @@index([organizationId])
}

model WorkflowRun {
  id             String    @id @default(cuid())
  workflowId     String
  status         String    @default("RUNNING") // RUNNING, SUCCESS, FAILED
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  triggerData    Json?     // Payload received
  runLogs        Json      @default("[]") // Detailed logs per node execution
  workflow       AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model PricingPlan {
  id                String         @id @default(cuid())
  name              String
  stripePriceId     String?        @unique
  flutterwavePlanId String?        @unique
  monthlyPrice      Float          @default(0)
  includedMinutes   Int            @default(0)
  includedSms       Int            @default(0)
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  organizations     Organization[]
  features          PlanFeature[]
}

model PlanFeature {
  id            String      @id @default(cuid())
  name          String
  pricingPlanId String
  pricingPlan   PricingPlan @relation(fields: [pricingPlanId], references: [id], onDelete: Cascade)

  @@index([pricingPlanId])
}

model AIEmployee {
  id        String  @id @default(cuid())
  name      String
  jobTitle  String  @default("Agent de Support Client")
  avatarUrl String?

  // Personality & Brain
  systemPrompt String @db.Text
  voiceId      String @default("alloy")
  language     String @default("fr-FR")

  // Assigned Channels
  handlesWhatsApp  Boolean @default(false)
  handlesVoice     Boolean @default(false)
  handlesInstagram Boolean @default(false)

  // Technical identifiers
  openaiAssistantId     String?
  voicePhoneNumberId    String? @unique
  whatsappPhoneNumberId String? // Optional if we link specifically

  // Social Hub
  roleType String @default("GENERAL") // GENERAL, FACEBOOK_MANAGER, LINKEDIN_MANAGER, TIKTOK_MANAGER, INSTAGRAM_MANAGER

  // Template Data
  templateId   String?
  selectedTone String?

  // Options
  isActive                 Boolean @default(true)
  tacticalSilence          Int     @default(4000)
  greeting                 String?
  replyToCommentsPublicly  Boolean @default(true)
  replyToCommentsPrivately Boolean @default(false)

  organizationId  String
  knowledgeBaseId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  voicePhoneNumber PhoneNumber?   @relation(fields: [voicePhoneNumberId], references: [id])
  knowledgeBase    KnowledgeBase? @relation(fields: [knowledgeBaseId], references: [id])
  socialAccount    SocialAccount?
  socialPosts      SocialPost[]
  socialMessages   SocialMessage[]
  template         AgentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  skills           AgentSkill[]

  @@index([organizationId])
  @@index([templateId])
}

model AgentTemplate {
  id           String   @id @default(cuid())
  name         String
  jobTitle     String
  roleType     String   @default("GENERAL") // e.g. FACEBOOK_MANAGER
  description  String?  @db.Text // CV / Profile
  systemPrompt String   @db.Text // Core prompt (Brain/Soul)
  tones        String   @db.Text // JSON array of available tones
  skills       String   @db.Text // JSON array of skills
  color        String?  @default("text-zinc-800")
  bgColor      String?  @default("bg-zinc-800/10")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  aiEmployees AIEmployee[]
}

model KnowledgeBase {
  id                  String   @id @default(cuid())
  name                String
  openaiVectorStoreId String?
  organizationId      String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents    KnowledgeDocument[]
  aiEmployees  AIEmployee[]

  @@index([organizationId])
}

model KnowledgeDocument {
  id              String   @id @default(cuid())
  type            String // 'FILE' or 'URL'
  name            String
  source          String // URL string or Original filename
  openaiFileId    String?
  status          String   @default("PROCESSING") // PROCESSING, READY, FAILED
  knowledgeBaseId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
}

model SimCard {
  id               String       @id @default(cuid())
  iccid            String       @unique
  telnyxSimId      String       @unique
  type             String       @default("ESIM")
  status           String       @default("ACTIVE")
  name             String?
  dataUsedMB       Float        @default(0.0)
  dataLimitMB      Float?
  alertEnabled     Boolean      @default(false)
  lpaCode          String?
  organizationId   String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  publicIpEnabled  Boolean      @default(false)
  voiceEnabled     Boolean      @default(false)
  voiceForwarding  String?
  voicePhoneNumber String?
  voiceScreening   String?
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model WalletTransaction {
  id             String       @id @default(cuid())
  amount         Float
  type           String
  description    String
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
}

model WhatsAppAccount {
  id             String       @id @default(cuid())
  wabaId         String
  phoneNumberId  String
  phoneNumber    String
  accessToken    String
  status         String       @default("ACTIVE")
  organizationId String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Campaign {
  id             String              @id @default(cuid())
  name           String
  channel        String              @default("WHATSAPP") // VOICE, WHATSAPP, MESSENGER
  status         String              @default("DRAFT")
  scheduledAt    DateTime?
  sentCount      Int                 @default(0)
  deliveredCount Int                 @default(0)
  readCount      Int                 @default(0)
  repliedCount   Int                 @default(0)
  templateId     String?
  body           String?
  botEnabled     Boolean             @default(false)
  aiGoal         String?
  organizationId String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  phoneNumberId  String?
  socialAccountId String?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumber    PhoneNumber?        @relation(fields: [phoneNumberId], references: [id])
  socialAccount  SocialAccount?      @relation(fields: [socialAccountId], references: [id])
  template       WhatsAppTemplate?   @relation(fields: [templateId], references: [id])
  recipients     CampaignRecipient[]

  @@index([organizationId])
  @@index([socialAccountId])
}

model CampaignRecipient {
  id         String   @id @default(cuid())
  campaignId String
  contactId  String
  status     String   @default("PENDING")
  messageId  String?
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
}

model WhatsAppTemplate {
  id             String       @id @default(cuid())
  name           String
  language       String       @default("fr")
  category       String       @default("MARKETING")
  status         String       @default("APPROVED")
  content        String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  campaigns      Campaign[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Opportunity {
  id              String         @id @default(cuid())
  name            String
  stage           String         @default("NEW")
  expectedRevenue Float          @default(0.0)
  probability     Int            @default(10)
  priority        Int            @default(0)
  contactId       String?
  organizationId  String
  assignedUserId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  internalNotes   InternalNote[]
  assignedUser    User?          @relation(fields: [assignedUserId], references: [id])
  contact         Contact?       @relation(fields: [contactId], references: [id])
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
}

model InternalNote {
  id             String       @id @default(cuid())
  content        String
  opportunityId  String?
  contactId      String?
  organizationId String
  authorId       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([opportunityId])
  @@index([contactId])
}

model SystemSettings {
  id                          String   @id @default("default")
  smsRate                     Float    @default(0.05)
  callRatePerMinute           Float    @default(0.02)
  aiAgentRatePerMinute        Float    @default(0.15)
  whatsappRate                Float    @default(0.02)
  phoneNumberRate             Float    @default(1.00)
  eSimRate                    Float    @default(5.00)
  telnyxApiKey                String?
  telnyxConnectionId          String?
  updatedAt                   DateTime @updatedAt
  phoneNumberMarkupFixed      Float    @default(0.0)
  phoneNumberMarkupMultiplier Float    @default(2.5)
}

model Sequence {
  id             String               @id @default(cuid())
  name           String
  description    String?
  isActive       Boolean              @default(false)
  organizationId String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollments    SequenceEnrollment[]
  steps          SequenceStep[]

  @@index([organizationId])
}

model SequenceStep {
  id         String   @id @default(cuid())
  sequenceId String
  stepOrder  Int
  delayHours Int
  actionType String
  content    String?
  templateId String?
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
}

model SequenceEnrollment {
  id          String    @id @default(cuid())
  sequenceId  String
  contactId   String
  currentStep Int       @default(1)
  status      String    @default("ACTIVE")
  nextRunAt   DateTime?
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sequence    Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, contactId])
  @@index([sequenceId])
  @@index([contactId])
}

model NumberOrder {
  id             String       @id @default(cuid())
  telnyxOrderId  String       @unique
  type           String
  status         String       @default("pending")
  phoneNumbers   String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

model VerifyProfile {
  id             String            @id
  name           String
  language       String            @default("en-US")
  settings       String?
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  logs           VerificationLog[]
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model VerificationLog {
  id              String        @id
  phoneNumber     String
  status          String        @default("pending")
  type            String
  verifyProfileId String
  organizationId  String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  verifyProfile   VerifyProfile @relation(fields: [verifyProfileId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([verifyProfileId])
  @@index([phoneNumber])
}

model RcsSettings {
  id                 String       @id @default(cuid())
  organizationId     String       @unique
  agentId            String?
  messagingProfileId String?
  aiEmployeeId       String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model WhatsAppFlow {
  id             String                   @id @default(cuid())
  name           String
  nodes          Json                     @default("[]")
  edges          Json                     @default("[]")
  isActive       Boolean                  @default(false)
  organizationId String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollments    WhatsAppFlowEnrollment[]

  @@index([organizationId])
}

model WhatsAppFlowEnrollment {
  id             String    @id @default(cuid())
  flowId         String
  contactId      String
  currentNodeId  String? // The ID of the current node executing or waiting
  status         String    @default("ACTIVE") // ACTIVE, COMPLETED, FAILED, PAUSED
  nextRunAt      DateTime? // If waiting on a Delay node
  variables      Json      @default("{}") // State variables for the flow run
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  flow         WhatsAppFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([flowId, contactId])
  @@index([flowId])
  @@index([contactId])
  @@index([organizationId])
  @@index([nextRunAt])
}

// ==========================================
// Phase 5 : E-Commerce & RAG
// ==========================================

// Models related to E-Commerce & Stores

model EcommerceStore {
  id                String       @id @default(cuid())
  platform          String       @default("SHOPIFY") // SHOPIFY, WOOCOMMERCE, CUSTOM
  storeUrl          String
  accessToken       String?
  webhookSecret     String?
  isActive          Boolean      @default(true)
  aiDiscountEnabled Boolean      @default(false)
  aiDiscountValue   String?
  organizationId    String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Cart {
  id             String   @id @default(cuid())
  externalCartId String // ID du panier sur Shopify/WooCommerce
  contactId      String?
  totalPrice     Float    @default(0.0)
  currency       String   @default("EUR")
  status         String   @default("ABANDONED") // ABANDONED, RECOVERED, COMPLETED
  checkoutUrl    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        CartItem[]

  @@unique([organizationId, externalCartId])
  @@index([organizationId])
  @@index([contactId])
}

model CartItem {
  id          String  @id @default(cuid())
  cartId      String
  productId   String
  productName String
  quantity    Int     @default(1)
  price       Float
  imageUrl    String?

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
}

// ==========================================
// Phase 8 : Ventes B2B (Devis & Factures)
// ==========================================

model Quote {
  id             String   @id @default(cuid())
  status         String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED
  amount         Float    @default(0.0)
  currency       String   @default("EUR")
  description    String?
  pdfUrl         String?
  contactId      String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
}

model Invoice {
  id             String   @id @default(cuid())
  status         String   @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE
  amount         Float    @default(0.0)
  currency       String   @default("EUR")
  description    String?
  pdfUrl         String?
  contactId      String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
}

// ==========================================
// Phase 8 : Support B2B (Ticketing / Helpdesk)
// ==========================================

model Ticket {
  id             String    @id @default(cuid())
  title          String
  description    String?   @db.Text
  status         String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority       String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  csatScore      Int? // 1 to 5
  csatComment    String?   @db.Text
  resolvedAt     DateTime?
  contactId      String
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
  @@index([status])
}

// ==========================================
// Phase 8 : Inventaire (Catalogue & Stocks)
// ==========================================

model Product {
  id             String   @id @default(cuid())
  sku            String?
  name           String
  description    String?  @db.Text
  price          Float    @default(0.0)
  stockLevel     Int      @default(0)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([sku])
}

// ==========================================
// Phase 9 : Hub of Delegation (Social Media)
// ==========================================

model SocialAccount {
  id           String  @id @default(cuid())
  provider     String // "FACEBOOK", "LINKEDIN", "TIKTOK", "INSTAGRAM"
  accountId    String // The ID from the provider
  accountName  String?
  accessToken  String  @db.Text
  refreshToken String? @db.Text
  status       String  @default("ACTIVE")

  organizationId String
  aiEmployeeId   String? @unique // One agent manages this specific account

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  aiEmployee   AIEmployee?  @relation(fields: [aiEmployeeId], references: [id], onDelete: SetNull)
  campaigns    Campaign[]

  @@index([organizationId])
}

model SocialPost {
  id          String    @id @default(cuid())
  platform    String // "FACEBOOK", "LINKEDIN"
  content     String    @db.Text
  mediaUrls   String?   @db.Text // JSON array or comma separated
  status      String    @default("DRAFT") // DRAFT, SCHEDULED, PUBLISHED, FAILED
  scheduledAt DateTime?

  organizationId String
  aiEmployeeId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  aiEmployee   AIEmployee   @relation(fields: [aiEmployeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([aiEmployeeId])
}

model AgentSkill {
  id               String   @id @default(cuid())
  name             String   // e.g., "check_stock"
  description      String   @db.Text
  endpointUrl      String
  method           String   @default("POST") // GET or POST
  parametersSchema Json?    // JSON schema for parameters
  headers          Json?    // Optional JSON for custom headers (like Auth)
  
  aiEmployeeId     String
  aiEmployee       AIEmployee @relation(fields: [aiEmployeeId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([aiEmployeeId])
}

model SocialMessage {
  id                String        @id @default(cuid())
  provider          String        // "FACEBOOK", "INSTAGRAM", "WHATSAPP"
  providerMessageId String?
  direction         String        // "INBOUND" or "OUTBOUND"
  content           String        @db.Text
  senderId          String
  recipientId       String
  
  contactId         String?
  aiEmployeeId      String?
  organizationId    String

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  contact           Contact?      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  aiEmployee        AIEmployee?   @relation(fields: [aiEmployeeId], references: [id], onDelete: SetNull)
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
  @@index([aiEmployeeId])
}
